<div class="ctitle">{{ t.title }}</div>
<div class="lrtable">
  {% for r in t.context.rows %}
  <div class="rank {% if r.rank == 1 %}r1{% elif r.rank == 2 %}r2{% else %}rN{% endif %}">#{{ r.rank }}</div>
  <div class="metric">{{ r.metric }}</div>
  <div class="meta">{{ r.detail }}</div>
  {% endfor %}
</div>
